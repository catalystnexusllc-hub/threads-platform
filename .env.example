# ──────────────────────────────────────────────────────────────────────────────
#  THREADS — Environment Variable Reference (FastAPI + PostgreSQL)
#
#  Copy this file to .env and fill in values for your environment.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (required) ─────────────────────────────────────────────────────
# PostgreSQL connection string. In Kubernetes this points at the in-cluster
# Postgres Service (StatefulSet); injected from the cluster Secret.
DATABASE_URL=postgresql://threads:threads@localhost:5432/threads

# ── Server ──────────────────────────────────────────────────────────────────
# Environment label echoed by /api/health: development | production | test
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. With the nginx + API split behind one
# ingress host the SPA is same-origin and CORS is effectively unused; keep it
# locked to the real frontend hostname(s) in production. Use "*" only in a
# fully-isolated airgap lab.
CORS_ORIGIN=http://localhost:3000

# ── Authentication ──────────────────────────────────────────────────────────
# API key required on ALL /api data endpoints — reads (GET) and writes
# (PUT/POST/DELETE) alike. /api/health stays open for k8s probes.
# Pass as: Authorization: Bearer <key>  or  X-Api-Key: <key>
# Leave empty to disable auth (local dev only — never unset in production).
API_KEY=
