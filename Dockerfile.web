# THREADS — web image: build the React/Vite app, serve it with nginx (which also
# reverse-proxies /api to the api service). Replaces the legacy static public/ SPA.
#
# Build:  docker build -f Dockerfile.web -t ghcr.io/catalystnexus/threads-web:2.4.1 .
#         (pass --build-arg VITE_API_KEY=... if the api enforces API_KEY)

# ── Stage 1: build the SPA ──────────────────────────────────────────────────
FROM node:22-alpine AS build
WORKDIR /web

# API key is build-time embedded into the bundle (Vite inlines VITE_* at build).
# Only acceptable behind the Zero-Trust / airgap boundary — it ships to the browser.
ARG VITE_API_KEY=""
ENV VITE_API_KEY=$VITE_API_KEY

COPY web/package.json web/package-lock.json ./
RUN npm ci
COPY web/ ./
RUN npm run build

# ── Stage 2: serve ──────────────────────────────────────────────────────────
FROM nginx:1.27-alpine
COPY nginx/threads.conf /etc/nginx/conf.d/default.conf
COPY --from=build /web/dist /usr/share/nginx/html
EXPOSE 80
