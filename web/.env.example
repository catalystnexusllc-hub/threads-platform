# THREADS web (Vite) — copy to .env for local dev. VITE_* vars are inlined into
# the client bundle at build time, so never put a real secret here for a public
# deployment — only acceptable behind the Zero-Trust / airgap boundary.

# API key sent as X-Api-Key on every request. Required only if the api enforces
# API_KEY (see the backend .env). Leave empty when the api runs with auth off.
VITE_API_KEY=

# In production the SPA is same-origin behind nginx (which proxies /api → api:8000),
# so no API base URL is needed. The Vite dev server proxies /api to localhost:8000
# (see vite.config.ts); override the dev port with PORT if needed.
